# Copy this file to .env and fill in the keys you need.
# Only the keys for the tools you intend to run are required.

# Required for all Anthropic tools (claude-code-cli, anthropic-api, claude-cli-*, claude-agent-sdk-*)
ANTHROPIC_API_KEY=

# Required for Greptile API tool
GREPTILE_API_KEY=

# Optional — only if running Gemini CLI / Google API eval tools
GEMINI_API_KEY=

# Optional — only if running Codex CLI / OpenAI API eval tools
OPENAI_API_KEY=
