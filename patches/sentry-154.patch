+        old_deadline: int | None,
+        new_deadline: int,
+        message_timestamp: int,
+        has_root_span: bool,
+    ) -> None:
+        """
+        Log when a segment's deadline is set or updated.
+
+        Args:
+            segment_key: Redis key for the segment
+            project_and_trace: String like "123:trace-id"
