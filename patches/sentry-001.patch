+            {overlayColors.map(color => (
+              <ColorSwatch
+                key={color}
+                $color={color}
+                $selected={overlayColor === color}
+                onClick={() => onOverlayColorChange(color)}
+                aria-label={t('Overlay color %s', color)}
+              />
+            ))}
+          </Flex>
+        }
+      >
+        <ColorTrigger $color={overlayColor} aria-label={t('Pick overlay color')} />
+      </Tooltip>
+    </Flex>
+  );
