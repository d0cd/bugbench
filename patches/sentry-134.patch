-
-export const PENDING_CLUSTER_STATS: ClusterStats = {
-  totalEvents: 0,
-  totalUsers: 0,
-  firstSeen: null,
-  lastSeen: null,
-  newIssuesCount: 0,
-  hasRegressedIssues: false,
-  isEscalating: false,
