-function formatClusterInfoForClipboard(cluster: ClusterSummary): string {
-  const lines: string[] = [];
-
-  lines.push(`## ${cluster.title}`);
-  lines.push('');
-
-  if (cluster.summary) {
-    lines.push('### Summary');
-    lines.push(cluster.summary);
-    lines.push('');
-  }
-
-  lines.push('### Group IDs');
-  lines.push(cluster.group_ids.join(', '));
-
-  return lines.join('\n');
-}
