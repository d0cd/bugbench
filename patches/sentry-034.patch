+    if payload.provider != "github":
+        return {}
+    tags: dict[str, str] = {}
+    try:
+        headers = orjson.loads(payload.request_headers)
+    except orjson.JSONDecodeError:
+        return {}
+    if isinstance(headers, dict):
+        for key, value in headers.items():
