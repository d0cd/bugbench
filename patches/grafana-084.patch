+func TestEvaluatePullCondition(t *testing.T) {
+	tests := []struct {
+		name           string
+		jobState       provisioning.JobState
+		resultReasons  []string
+		expectedType   string
+		expectedStatus metav1.ConditionStatus
+		expectedReason string
+		expectedMsg    string
+	}{
+		{
