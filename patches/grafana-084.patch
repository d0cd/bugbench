+			},
+			lokiResponse: createMockAlertLokiResponse(testTimestamp),
+			experr:       ErrInvalidQuery,
+		},
+		{
+			name:          "loki error is propagated",
+			query:         AlertQuery{Uuid: stringPtr("test-uuid")},
