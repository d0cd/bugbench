+
+            let expected = first.pow(second.to_repr().0);
+            let a = Field::<Circuit>::new(Mode::Constant, first);
+            let b = Field::<Circuit>::new(Mode::Constant, second);
+
+            let name = format!("Pow: a^b {}", i);
+            check_pow(&name, &expected, &a, &b, 253, 0, 0, 0);
+        }
+    }
+
