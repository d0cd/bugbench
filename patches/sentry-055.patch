+        eap_rows = _project_key_performance_issues_eap(ctx, self.project, referrer, group_ids)
+
+        assert len(snuba_rows) == 2
+        assert len(eap_rows) == 2
+        for snuba_row, eap_row in zip(snuba_rows, eap_rows):
