+function getUniformDatasource(queries: DataQuery[]): DataSourceRef | undefined {
+  const regularQueries = queries.filter((q) => !isExpressionReference(q.datasource));
+  if (regularQueries.length === 0) {
+    return undefined;
+  }
+
