-    /// Shuts down the primary.
-    pub async fn shut_down(&self) {
-        info!("Shutting down the sync module...");
-        // Acquire the sync lock.
-        let _lock = self.lock.lock().await;
-        // Abort the tasks.
-        self.handles.lock().iter().for_each(|handle| handle.abort());
-    }
-}
