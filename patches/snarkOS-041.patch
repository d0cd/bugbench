+    /// Returns `true` if the node is in development mode.
+    pub fn is_dev(&self) -> bool {
+        match self {
+            Self::Beacon(node) => node.is_dev(),
+            Self::Validator(node) => node.is_dev(),
+            Self::Prover(node) => node.is_dev(),
+            Self::Client(node) => node.is_dev(),
+        }
     }
 }
