-            let sleep_ms = (subdag_ms + transmissions_ms + constant_ms) as u64;
-            // Sleep for the determined amount of time.
-            tokio::time::sleep(std::time::Duration::from_millis(sleep_ms)).await;
-            // Call the callback.
-            callback.send(Ok(())).ok();
-        }
-    });
