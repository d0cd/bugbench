-    /// Insert a new timestamp for the given key, returning the number of recent entries.
-    fn retain_and_insert<K: Copy + Clone + PartialEq + Eq + Hash>(
-        map: &RwLock<BTreeMap<i64, HashMap<K, u32>>>,
-        key: K,
-        interval_in_secs: i64,
