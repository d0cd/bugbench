+				Spec: provisioning.RepositorySpec{
+					Type: provisioning.GitHubRepositoryType,
+				},
+			},
+		}
+
+		err := gitRepo.Move(context.Background(), "old.yaml", "existing.yaml", "main", "commit")
+		require.ErrorIs(t, err, repository.ErrFileAlreadyExists)
+	})
+}
