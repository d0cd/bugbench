+	}
+	if groupBy.Integration {
+		labels = append(labels, "integration")
+	}
+	if groupBy.IntegrationIndex {
+		labels = append(labels, "integrationIdx")
+	}
+	if groupBy.Status {
+		labels = append(labels, "status")
+	}
+	if groupBy.Outcome {
+		labels = append(labels, "outcome")
+	}
+	if groupBy.Error {
+		labels = append(labels, "error")
+	}
+	sumBy := ""
