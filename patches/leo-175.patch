+///
+/// Checks if a char is a Unicode Bidirectional Override code point
+///
+fn is_bidi_override(c: char) -> bool {
+    let i = c as u32;
+    return (0x202A <= i && i <= 0x202E) || (0x2066 <= i && i <= 0x2069);
+}
