+export function setupCorrelationsMswServer() {
+  const server = setupMockServer();
+
+  setBackendSrv(backendSrv);
+
+  beforeEach(() => {
+    resetFixtures();
+  });
+
+  afterEach(() => {
+    server.resetHandlers();
+  });
+
+  afterAll(() => {
+    server.close();
+  });
+
+  return server;
+}
