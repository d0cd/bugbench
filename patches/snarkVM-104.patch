-            col: COL_BLOCK_TRANSACTIONS,
-            key: block_hash_bytes.to_vec(),
-            value: to_bytes_le![block.transactions]?.to_vec(),
-        });
-
-        database_transaction.push(Op::Insert {
-            col: COL_BLOCK_TRANSACTIONS,
-            key: block_hash_bytes.to_vec(),
-            value: to_bytes_le![block.transactions]?.to_vec(),
