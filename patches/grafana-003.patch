+	// processFn blocks forever to simulate a stuck reconciliation
+	rc.processFn = func(item *queueItem) error {
+		select {}
+	}
+
+	rc.queue.Add(&queueItem{key: "test/stuck"})
+
+	ctx, cancel := context.WithCancel(context.Background())
