+func getLegacyIDSelector(labels []*resourcepb.Requirement) int64 {
+	if len(labels) != 1 {
+		return 0
+	}
+	q := labels[0]
+	if q.Key == utils.LabelKeyDeprecatedInternalID &&
+		q.Operator == "=" &&
+		len(q.Values) == 1 {
+		i, _ := strconv.ParseInt(labels[0].Values[0], 10, 64)
+		return i
+	}
+	return 0
+}
