+class TempestTasksLockingTest(TestCase):
+    """Tests for task locking to prevent overlapping execution."""
+
+    def setUp(self) -> None:
+        super().setUp()
+        self.project = self.create_project()
+        self.credentials = self.create_tempest_credentials(self.project)
