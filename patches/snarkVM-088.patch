+macro_rules! test_atomic_finalize {
+    ($store:ident, $mode:expr, $test:block) => {{
+        // The test closure.
+        let mut run = || -> Result<()> { atomic_finalize!($store, $mode, $test) };
+        // Run the test.
+        run()
+    }};
+}
+pub(super) use test_atomic_finalize;
