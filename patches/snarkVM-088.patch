+/// Samples a new finalize store.
+macro_rules! sample_finalize_store {
+    () => {{
+        #[cfg(feature = "rocks")]
+        let temp_dir = tempfile::tempdir().expect("Failed to open temporary directory");
+        #[cfg(not(feature = "rocks"))]
+        let temp_dir = ();
