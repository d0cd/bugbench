diff --git a/packages/trpc/server/routers/viewer/teams/hasTeamMembership.handler.ts b/packages/trpc/server/routers/viewer/teams/hasTeamMembership.handler.ts
new file mode 100644
index 00000000000000..d05c5c3bdc7731
--- /dev/null
+++ b/packages/trpc/server/routers/viewer/teams/hasTeamMembership.handler.ts
@@ -0,0 +1,15 @@
+import { MembershipRepository } from "@calcom/features/membership/repositories/MembershipRepository";
+
+type HasTeamMembershipOptions = {
+  ctx: {
+    user: { id: number };
+  };
+};
+
+export const hasTeamMembershipHandler = async ({ ctx }: HasTeamMembershipOptions) => {
+  const userId = ctx.user.id;
+  const hasTeamMembership = await MembershipRepository.hasAnyTeamMembershipByUserId({ userId });
+  return { hasTeamMembership };
+};
+
+export default hasTeamMembershipHandler;
