+    ) -> PaginatedActionResult[PullRequest]:
+        raw = []
+        gitlab_states: list[str] | list[None]
+        if state:
+            gitlab_states = PULL_REQUEST_STATE_RETRIEVE_MAP[state]
+        else:
+            gitlab_states = [None]
+        for gitlab_state in gitlab_states:
