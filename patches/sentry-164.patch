+def test_forward_to_client(client, provider: GitLabProvider, param: ForwardToClientTest):
+    # Setup client mock return values
+    for client_call in param.client_calls:
+        getattr(client, client_call.client_method).return_value = client_call.client_return_value
+
+    # Call the provider, check the return value
+    assert param.provider_method(provider, **param.provider_args) == param.provider_return_value
+
+    # Check client calls (method and args)
+    assert len(client.mock_calls) == len(param.client_calls)
+    for client_call, mock_call in zip(param.client_calls, client.mock_calls):
+        assert mock_call[0] == client_call.client_method
+        assert mock_call[1] == client_call.client_args
+        assert mock_call[2] == client_call.client_kwds
