+      });
+
+      expect(mockTraceService.addStep).toHaveBeenCalledWith({
+        domain: ROUTING_TRACE_DOMAINS.ROUTING_FORM,
+        step: ROUTING_FORM_STEPS.ATTRIBUTE_LOGIC_EVALUATED,
