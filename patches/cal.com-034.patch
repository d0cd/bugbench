+    routingTrace: {
+      create: vi.fn(),
+    },
+  } as unknown as PrismaClient;
+
+  beforeEach(() => {
+    vi.clearAllMocks();
+    repository = new PrismaRoutingTraceRepository(mockPrisma);
+  });
+
+  describe("create", () => {
+    it("should create a routing trace with all fields", async () => {
