+
+    event: SubscriptionEvent = {
+        "event": "",
+        "event_type_hint": "pull_request",
+        "extra": {},
+        "received_at": 0,
+        "sentry_meta": [],
+        "type": "github",
+    }
+    produce_event_to_scm_stream(
+        event,
+        "control",
+        record_count=record_count,
+        report_error=report_error,
