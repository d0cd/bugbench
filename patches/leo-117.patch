+    type Options = (Option<bool>, bool);
+    type Output = ();
+
+    const ABOUT: AboutType = "Setting for automatic updates of Leo";
+    const ARGUMENTS: &'static [ArgumentType] = &[
+        // (name, description, possible_values, required, index)
