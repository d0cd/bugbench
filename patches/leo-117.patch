+            "Enable or disable automatic updates",
+            &["true", "false"],
+            false,
+            1u64,
+        ),
+    ];
+    const FLAGS: &'static [FlagType] = &["[quiet] -q --quiet 'Suppress outputs to terminal'"];
+    const NAME: NameType = "automatic";
