new file mode 100644
index 0000000000..f4d8de0c08
--- /dev/null
+++ b/compiler/passes/src/static_analysis/future_checker.rs
@@ -0,0 +1,167 @@
+// Copyright (C) 2019-2024 Aleo Systems Inc.
+// This file is part of the Leo library.
