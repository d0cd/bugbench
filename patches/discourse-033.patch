@@ -0,0 +1,72 @@
+@use "lib/viewport";
+
+.admin-new-category-setup {
+  .category-type-cards {
+    display: flex;
+    flex-direction: column;
+    gap: var(--space-6);
+    margin-top: var(--space-8);
+
+    &__card {
+      all: unset; // reset browser button styles
+      position: relative;
+      display: grid;
+      grid-template-areas: "icon title" "icon description";
+      grid-template-columns: auto 1fr;
+      cursor: pointer;
+      text-align: left;
+      gap: 0 var(--space-6);
+      border: 1px solid var(--primary-low);
+      border-radius: var(--d-border-radius);
+      padding: var(--space-9) var(--space-6);
+
+      @include viewport.from(sm) {
+        padding: var(--space-8) var(--space-8) var(--space-9);
+        gap: 0 var(--space-8);
+      }
+
+      &-icon {
+        grid-area: icon;
+        font-size: 2.75em;
+        margin-top: -0.1em;
+      }
+
+      &-name {
+        grid-area: title;
+        font-size: var(--font-up-1);
+        font-weight: bold;
+      }
+
+      &-description {
+        grid-area: description;
+        color: var(--primary-high);
+      }
+
+      &:hover,
+      &:focus-visible {
+        border-color: var(--tertiary);
+      }
+
+      &.--unavailable {
+        opacity: 0.5;
+        cursor: not-allowed;
+
+        &:hover,
+        &:focus-visible {
+          border-color: var(--primary-low);
+        }
+      }
+    }
+
+    &__card-badge {
+      position: absolute;
+      right: 0;
+      font-size: var(--font-down-2);
+      color: var(--primary);
+      padding: var(--space-1) var(--space-2);
+      background: var(--highlight-low);
+      border-radius: 0 calc(var(--d-border-radius) - 1px) 0
+        var(--d-border-radius);
+    }
+  }
+}
