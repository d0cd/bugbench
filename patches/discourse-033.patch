--- /dev/null
+++ b/frontend/asset-processor/federated-modules-helper.js
@@ -0,0 +1,8 @@
+export function federatedExportNameFor(moduleName, exportedName) {
+  if (exportedName === "*") {
+    exportedName = "__module";
+  }
+  return (
+    moduleName.replaceAll("/", "$").replaceAll("-", "__") + "$$" + exportedName
+  );
+}
