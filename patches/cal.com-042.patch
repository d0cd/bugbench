+  token,
+  classs: PrismaRoutingTraceRepository,
+  dep: prismaModuleLoader,
+});
+
+export const moduleLoader: ModuleLoader = {
+  token,
+  loadModule,
+};
+
+export type { PrismaRoutingTraceRepository };
