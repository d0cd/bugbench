+  def self.match_word_regexp(regexp, engine: :ruby)
     s = SPACELESS_SCRIPTS
-    w = WORD_CHARS
-    leading = "(?:(?<!#{w})|(?<=[#{s}])|(?=[#{s}]))"
-    trailing = "(?:(?!#{w})|(?=[#{s}])|(?<=[#{s}]))"
