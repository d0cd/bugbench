diff --git a/frontend/asset-processor/rollup-plugins/discourse-extension-search.js b/frontend/asset-processor/rollup-plugins/discourse-extension-search.js
new file mode 100644
index 0000000000..fce938f95e
--- /dev/null
+++ b/frontend/asset-processor/rollup-plugins/discourse-extension-search.js
@@ -0,0 +1,21 @@
+export default function discourseExtensionSearch() {
+  return {
+    name: "discourse-extension-search",
+    async resolveId(source, context) {
+      if (source.match(/\.\w+$/)) {
+        // Already has an extension
+        return null;
+      }
+
+      for (const ext of ["", ".js", ".gjs", ".hbs"]) {
+        const resolved = await this.resolve(`${source}${ext}`, context);
+
+        if (resolved) {
+          return resolved;
+        }
+      }
+
+      return null;
+    },
+  };
+}
