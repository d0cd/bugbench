+# Derived indexes built at module load
+_FRAMEWORKS_BY_PLATFORM: dict[str, list[FrameworkDef]] = defaultdict(list)
+for _fw in FRAMEWORKS:
+    _FRAMEWORKS_BY_PLATFORM[_fw["base_platform"]].append(_fw)
