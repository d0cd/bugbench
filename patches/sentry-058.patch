+            priority="transparent"
+          />
+          <Button
+            size="xs"
+            icon={<IconRefresh />}
+            onClick={onReset}
+            disabled={!onReset}
+            tooltipProps={{title: t('Start a new analysis from scratch')}}
+            aria-label={t('Start a new analysis from scratch')}
+            priority="transparent"
+          />
+        </Flex>
+        <AutofixFeedback iconOnly priority="transparent" />
+      </Flex>
+    </DrawerHeader>
+  );
+}
diff --git a/static/app/components/events/autofix/v3/utils.spec.ts b/static/app/components/events/autofix/v3/utils.spec.ts
