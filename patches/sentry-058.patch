+def format_request_data(
+    data: ProjectRulePostData,
+) -> dict[str, Any]:
+    workflow_payload = {
+        "name": data.get("name"),
+        "enabled": data.get("status", "active") == "active",
+        "environment": data.get("environment"),
+        "config": {"frequency": data.get("frequency")},
