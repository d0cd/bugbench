diff --git a/tests/base/src/test/java/org/keycloak/tests/oauth/OfflineTokenCrossUserSessionIsolationTest.java b/tests/base/src/test/java/org/keycloak/tests/oauth/OfflineTokenCrossUserSessionIsolationTest.java
