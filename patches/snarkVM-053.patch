+        let a_bit = UInt8::alloc(cs.ns(|| "a_bit"), || Ok(a)).unwrap();
+        let b_bit =
+            if b > u8::MAX / 4 { UInt8::constant(b) } else { UInt8::alloc(cs.ns(|| "b_bit"), || Ok(b)).unwrap() };
