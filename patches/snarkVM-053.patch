+impl<F, CF> IntoIterator for NonNativeFieldInputVar<F, CF>
+where
+    F: PrimeField,
+    CF: PrimeField,
+{
+    type IntoIter = std::vec::IntoIter<NonNativeFieldVar<F, CF>>;
+    type Item = NonNativeFieldVar<F, CF>;
+
+    fn into_iter(self) -> Self::IntoIter {
+        self.val.into_iter()
+    }
+}
