+impl<F: PrimeField> ToConstraintFieldGadget<F> for Vec<Boolean> {
+    fn to_constraint_field<CS: ConstraintSystem<F>>(&self, cs: CS) -> Result<Vec<FpGadget<F>>, SynthesisError> {
+        self.as_slice().to_constraint_field(cs)
+    }
+}
