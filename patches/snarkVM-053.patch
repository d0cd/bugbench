+            assert!(Boolean::enforce_nand(&mut cs, &[Boolean::constant(true)]).is_err());
+        }
+
+        for i in 1..5 {
+            // with every possible assignment for them
+            for mut b in 0..(1 << i) {
+                // with every possible negation
+                for mut n in 0..(1 << i) {
+                    let mut cs = TestConstraintSystem::<Fr>::new();
+
+                    let mut expected = true;
