+            Self::Constant(_) => self.to_bits_le_strict(cs.ns(|| "to_bits_strict")),
+            Self::Var(v) => v.to_bits_le(cs.ns(|| "to_bits")),
+        }
+    }
+
+    fn to_bits_le_strict<CS: ConstraintSystem<BaseField>>(&self, mut cs: CS) -> Result<Vec<Boolean>, SynthesisError> {
+        match self {
