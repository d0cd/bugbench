+impl<F: PrimeField> EvaluateEqGadget<F> for Boolean {
+    fn evaluate_equal<CS: ConstraintSystem<F>>(&self, cs: CS, other: &Self) -> Result<Boolean, SynthesisError> {
+        let xor = self.xor(cs, other)?;
+        Ok(xor.not())
+    }
+}
