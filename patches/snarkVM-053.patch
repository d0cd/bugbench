+#[test]
+fn test_uint8_rotr() {
+    let mut rng = test_rng();
+
+    let mut num = rng.gen();
+
+    let a = UInt8::constant(num);
+
+    for i in 0..8 {
+        let b = a.rotr(i);
+
+        assert!(b.value.unwrap() == num);
+
+        let mut tmp = num;
+        for b in &b.bits {
+            match *b {
+                Boolean::Constant(b) => {
+                    assert_eq!(b, tmp & 1 == 1);
+                }
+                _ => unreachable!(),
+            }
+
+            tmp >>= 1;
+        }
+
+        num = num.rotate_right(1);
+    }
+}
