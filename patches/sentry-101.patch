+        rv = buffer.flush_segments(now=12)
+        assert len(rv) == 1
+        buffer.done_flush_segments(rv)
+
+        rv = buffer.flush_segments(now=13)
+        assert len(rv) == 1
+        buffer.done_flush_segments(rv)
