diff --git a/tests/compiler/function/function_returns_record_fail.leo b/tests/compiler/function/function_returns_record_fail.leo
new file mode 100644
index 0000000000..c4896f06be
--- /dev/null
+++ b/tests/compiler/function/function_returns_record_fail.leo
@@ -0,0 +1,32 @@
+/*
+namespace: Compile
+expectation: Fail
+*/
+
+program test.aleo {
+    record Board {
+        owner: address,
+        gates: u64,
+        data: u8,
+    }
+
+    function foo(board: Board, data: u8) -> Board {
+        return Board {
+            owner: board.owner,
+            gates: board.gates,
+            data: data,
+        };
+    }
+
+    function bar(board: Board) {
+        assert_eq(board.gates, 0u64);
+    }
+
+    transition main(board: Board) -> Board {
+        bar(board);
+        return foo(board, 1u8);
+    }
+
+
+
+}
