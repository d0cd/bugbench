+      backgroundColor: theme.colors.background.primary,
+    }),
+    controlsExpandedButton: css({
+      transform: !controlsExpanded ? 'rotate(180deg)' : '',
+    }),
+    controlButton: css({
+      margin: 0,
+      color: theme.colors.text.secondary,
+      height: theme.spacing(2),
+    }),
+  };
+};
