diff --git a/tests/tests/compiler/storage/aggregates.leo b/tests/tests/compiler/storage/aggregates.leo
new file mode 100644
index 0000000000..31e59a5f52
--- /dev/null
+++ b/tests/tests/compiler/storage/aggregates.leo
@@ -0,0 +1,144 @@
+program complex.aleo {
+    //
+    // ────────────────────────────────────────────────────────────────
+    // Struct and array storage declarations
+    // ────────────────────────────────────────────────────────────────
+    //
+    struct Point {
+        x: field,
+        y: field,
+    }
+
+    struct Stats {
+        values: [u32; 3],
+        active: bool,
+    }
+
+    storage point: Point;
+    storage points: [Point; 2];
+    storage stats: Stats;
+    storage arr_u32: [u32; 3];
+    storage arr_bool: [bool; 2];
+    storage nested: [[u8; 2]; 2];
+
+    //
+    // ────────────────────────────────────────────────────────────────
+    // Initialization
+    // ────────────────────────────────────────────────────────────────
+    //
+    async transition initialize() -> Future {
+        return async {
+            // Structs
+            point = Point { x: 1field, y: 2field };
+            points = [
+                Point { x: 10field, y: 20field },
+                Point { x: 30field, y: 40field },
+            ];
+
+            stats = Stats { values: [5u32, 10u32, 15u32], active: true };
+
+            // Arrays
+            arr_u32 = [7u32, 8u32, 9u32];
+            arr_bool = [true, false];
+            nested = [[1u8, 2u8], [3u8, 4u8]];
+        };
+    }
+
+    //
+    // ────────────────────────────────────────────────────────────────
+    // Unset everything 
+    // ────────────────────────────────────────────────────────────────
+    //
+    async transition to_none() -> Future {
+        return async {
+            // Integers
+            point = none;
+            points = none;
+            stats = none;
+            arr_u32 = none;
+            arr_bool = none;
+            nested = none;
+        };
+    }
+
+    //
+    // ────────────────────────────────────────────────────────────────
+    // Direct unwrap checks
+    // ────────────────────────────────────────────────────────────────
+    //
+    async transition check1() -> Future {
+        return async {
+            // Struct
+            let p = point.unwrap();
+            assert(p.x == 1field);
+            assert(p.y == 2field);
+
+            // Array of structs
+            let ps = points.unwrap();
+            assert(ps[0].x == 10field);
+            assert(ps[1].y == 40field);
+
+            // Nested structs
+            let s = stats.unwrap();
+            assert(s.values[1] == 10u32);
+            assert(s.active == true);
+
+            // Arrays
+            let a = arr_u32.unwrap();
+            assert(a[2] == 9u32);
+
+            let b = arr_bool.unwrap();
+            assert(b[0] == true);
+            assert(b[1] == false);
+
+            let n = nested.unwrap();
+            assert(n[0][1] == 2u8);
+            assert(n[1][0] == 3u8);
+        };
+    }
+
+    //
+    // ────────────────────────────────────────────────────────────────
+    // unwrap_or checks (fallback behavior)
+    // ────────────────────────────────────────────────────────────────
+    //
+    async transition check2() -> Future {
+        return async {
+            // Struct
+            let p = point.unwrap_or(Point { x: 0field, y: 0field });
+            assert(p.x == 1field);
+            assert(p.y == 2field);
+
+            // Array of structs
+            let ps = points.unwrap_or([
+                Point { x: 0field, y: 0field },
+                Point { x: 0field, y: 0field },
+            ]);
+            assert(ps[0].x == 10field);
+            assert(ps[1].y == 40field);
+
+            // Struct with array
+            let s = stats.unwrap_or(Stats { values: [0u32, 0u32, 0u32], active: false });
+            assert(s.values[2] == 15u32);
+            assert(s.active == true);
+
+            // Arrays
+            let a = arr_u32.unwrap_or([0u32, 0u32, 0u32]);
+            assert(a[1] == 8u32);
+
+            let b = arr_bool.unwrap_or([false, false]);
+            assert(b[0] == true);
+
+            let n = nested.unwrap_or([[0u8, 0u8], [0u8, 0u8]]);
+            assert(n[1][1] == 4u8);
+        };
+    }
+
+    //
+    // ────────────────────────────────────────────────────────────────
+    // No-upgrade constructor
+    // ────────────────────────────────────────────────────────────────
+    //
+    @noupgrade
+    async constructor() {}
+}
diff --git a/tests/tests/compiler/storage/bad_storage_ops_fail.leo b/tests/tests/compiler/storage/bad_storage_ops_fail.leo
new file mode 100644
index 0000000000..323c73a3c7
--- /dev/null
+++ b/tests/tests/compiler/storage/bad_storage_ops_fail.leo
@@ -0,0 +1,53 @@
+program st.aleo {
+    storage s_field: field;
+    storage s_vec: [u32];
+    mapping s_map: u32 => u32;
+
+    async transition assign_optional() -> Future {
+        return async {
+            let opt_val: field? = 5field;
+            s_field = opt_val; // ❌ illegal
+        };
+    }
+
+    async transition assign_to_vector() -> Future {
+        return async {
+            s_vec = [1u32, 2u32]; // ❌ cannot assign whole vector directly
+            s_vec = none;         // ❌ cannot assign none to a storage vector
+        };
+    }
+
+    async transition assign_vector_to_var() -> Future {
+        return async {
+            let local_vec1 = s_vec;       // ❌ cannot move storage vector
+            let local_vec2 = [0u32; 2];
+            local_vec2 = s_vec;           // ❌ cannot copy storage vector
+        };
+    }
+
+    async transition wrong_vector_ops() -> Future {
+        return async {
+            let x: field = 5field;
+            x.push(3field);        // ❌ not a vector
+            x.pop();               // ❌ not a vector
+            x.len();               // ❌ not a vector
+            x.swap_remove(0u32);   // ❌ not a vector
+            x.set(0u32, 1field);   // ❌ not a vector
+            x.get(0u32);           // ❌ not a vector
+        };
+    }
+
