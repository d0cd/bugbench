+    name?: string;
+    timeZone?: string;
+    availability?: Array<{
+      days: string[];
+      startTime: string;
+      endTime: string;
+    }>;
+    overrides?: Array<{
+      date: string;
+      startTime: string;
+      endTime: string;
+    }>;
+  }
+): Promise<Schedule> {
+  try {
+    // Sanitize the updates to remove null values
+    const sanitizedUpdates = sanitizePayload(updates as Record<string, unknown>);
+    const response = await makeRequest<{ status: string; data: Schedule }>(
+      `/schedules/${scheduleId}`,
+      {
+        method: "PATCH",
