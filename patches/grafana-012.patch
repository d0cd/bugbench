+		}
+
+		parsed := &resources.ParsedResource{
+			Existing: obj,
+			Obj:      obj,
+			Meta:     meta,
+			GVR:      gvr,
+		}
+		if err := authorizer.AuthorizeResource(ctx, parsed, verb); err != nil {
+			return fmt.Errorf("authorize %s %s/%s/%s: %w", action, ref.Group, ref.Kind, ref.Name, err)
