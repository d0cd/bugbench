+
+impl<'a> VisitorDirector<'a> for Director<'a> {
+    type Visitor = TypeChecker<'a>;
+
+    fn visitor(self) -> Self::Visitor {
+        self.visitor
+    }
+
+    fn visitor_ref(&mut self) -> &mut Self::Visitor {
+        &mut self.visitor
+    }
+}
