+            {
+                "appId": "com.example.app",
+                "platform": "android",
+                "buildConfiguration": "debug",
+                "codesigningType": "enterprise",
+            },
+        )
+        assert response.json()["latestArtifact"]["buildId"] == str(combo.id)
+
+    def test_filter_no_match(self):
