+++ b/packages/trpc/server/routers/viewer/organizations/sendPasswordReset.schema.ts
@@ -0,0 +1,7 @@
+import { z } from "zod";
+
+export const ZOrgPasswordResetSchema = z.object({
+  userId: z.number(),
+});
+
+export type TOrgPasswordResetSchema = z.infer<typeof ZOrgPasswordResetSchema>;
