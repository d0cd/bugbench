+		},
+		{
+			name: "multiple label matchers",
+			labels: Matchers{
+				{Type: "=", Label: "alertname", Value: "HighCPU"},
+				{Type: "!=", Label: "severity", Value: "info"},
+				{Type: "=~", Label: "env", Value: "prod|staging"},
