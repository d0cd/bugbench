+	}{
+		{
+			name:        "no sources returns empty list",
+			registry:    &fakeSourceRegistry{},
+			expectedIDs: nil,
+		},
+		{
+			name: "returns only app plugins",
+			registry: &fakeSourceRegistry{
+				sources: []plugins.PluginSource{
