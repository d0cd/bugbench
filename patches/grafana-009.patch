+
+    await userEvent.click(screen.getByRole('button', { name: 'Save' }));
+
+    expect(onAnnotationUpdate).toHaveBeenCalledWith({
+      id: 4683,
+      tags: ['tag1', 'tag2'],
+      description: 'My description',
+      from: 1759388895560,
+      to: 1759389095560,
+    });
+  });
+});
diff --git a/public/app/plugins/panel/timeseries/plugins/annotations2-cluster/AnnotationEditor2.tsx b/public/app/plugins/panel/timeseries/plugins/annotations2-cluster/AnnotationEditor2.tsx
