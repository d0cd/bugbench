+    $data: new DashboardDataLayerSet({ annotationLayers: [] }),
+    isEditing: true,
+    body: new DefaultGridLayoutManager({
+      grid: new SceneGridLayout({
+        children: [new DashboardGridItem({ body: new VizPanel({ key: 'panel-1', pluginId: 'text' }) })],
+      }),
+    }),
+  });
+  return testScene;
+}
