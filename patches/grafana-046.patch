+				// Parent folder metadata read fails
+				reader.On("Read", mock.Anything, "team-a/_folder.json", testRef).
+					Return(nil, fmt.Errorf("permission denied"))
+			},
+			expectedErr: true,
+			description: "When parent folder ID resolution fails, propagate error",
+		},
