-            };
-            let store = ConsensusStore::<CurrentNetwork, ConsensusMemory<CurrentNetwork>>::open(storage_mode)?;
-
-            // Initialize the VM.
-            let vm = VM::from(store)?;
-
-            // Prepare the fee.
