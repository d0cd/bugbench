new file mode 100644
index 000000000..ba42a5eed
--- /dev/null
+++ b/node/store/src/block.rs
@@ -0,0 +1,143 @@
+// Copyright (C) 2019-2022 Aleo Systems Inc.
+// This file is part of the snarkOS library.
