-impl<N: Network> DAG<N> {
-    /// Initializes a new DAG.
-    pub fn new() -> Self {
-        Self { graph: Default::default(), recent_committed_ids: Default::default(), last_committed_round: 0 }
-    }
-
-    /// Returns the DAG.
