-    let filter = tracing_subscriber::EnvFilter::from_default_env()
-        .add_directive("snarkos=off".parse().unwrap())
-        .add_directive("tokio_util=off".parse().unwrap())
-        .add_directive("mio=off".parse().unwrap());
-
-    // Initialize tracing.
