-                        // Wait for 1s so that the next entry doesn't overwrite the first one.
-                        thread::sleep(Duration::from_secs(1));
-                        // Insert an input, recent events should be 2.
-                        assert_eq!(cache.[<insert_ $name>](input, INTERVAL_IN_SECS), 2);
-                        // Wait for 1s so that the next entry doesn't overwrite the first one.
-                        thread::sleep(Duration::from_secs(1));
