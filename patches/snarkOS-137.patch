+                latest_block.last_coinbase_timestamp(),
+                next_timestamp,
+                next_height,
+                N::STARTING_SUPPLY,
+                N::ANCHOR_TIME,
+            )?;
+
+            // Compute the cumulative proof target of the prover solutions as a u128.
+            let cumulative_proof_target: u128 = prover_solutions.iter().try_fold(0u128, |cumulative, solution| {
