+                check_run_id, status=status, conclusion=conclusion, output=output
+            )
+        )
+
+    def minimize_comment(self, comment_node_id: str, reason: str) -> None:
+        return self._exec(lambda p: p.minimize_comment(comment_node_id, reason))
