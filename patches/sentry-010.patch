diff --git a/.github/workflows/update-baseline.yml b/.github/workflows/update-baseline.yml
new file mode 100644
index 00000000000000..35ecef2f0e6f2d
--- /dev/null
+++ b/.github/workflows/update-baseline.yml
@@ -0,0 +1,50 @@
+name: Update baseline-browser-mapping
+on:
+  # baseline-browser-mapping (browserslist) marks itself as stale after 2 months
+  # this GHA runs monthly to keep the baseline fresh
+  workflow_dispatch:
+  schedule:
+    # 1st of every month at 10am SF time (17:00 UTC)
+    - cron: '0 17 1 * *'
+
+jobs:
+  update:
+    runs-on: ubuntu-latest
+    permissions:
+      contents: write
+      pull-requests: write
+    steps:
+      - uses: actions/checkout@692973e3d937129bcbf40652eb9f2f61becf3332 # v4.1.7
+
+      - uses: ./.github/actions/setup-node-pnpm
+
+      - name: Update baseline-browser-mapping
+        run: pnpm update baseline-browser-mapping
+
+      - name: Check for changes
+        id: diff
+        run: |
+          if git diff --quiet pnpm-lock.yaml; then
+            echo "changed=false" >> "$GITHUB_OUTPUT"
+          else
+            echo "changed=true" >> "$GITHUB_OUTPUT"
+          fi
+
+      - name: Create Pull Request
+        if: steps.diff.outputs.changed == 'true'
+        env:
+          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+        run: |
+          git config user.name "github-actions[bot]"
+          git config user.email "github-actions[bot]@users.noreply.github.com"
+          BRANCH="chore/update-baseline"
+          git switch -C "$BRANCH"
+          git add pnpm-lock.yaml
+          git commit -m "chore(deps): update baseline-browser-mapping"
+          git push -f origin "$BRANCH"
+          # Create PR only if one doesn't already exist
+          if ! gh pr list --head "$BRANCH" --state open | grep -q .; then
+            gh pr create \
+              --title "chore(deps): update baseline-browser-mapping" \
+              --body "automated update of [\`baseline-browser-mapping\`](https://npmx.dev/package/baseline-browser-mapping) to suppress stale-data console warnings"
+          fi
