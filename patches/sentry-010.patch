+          }
+
+          if (message.content && message.content !== 'Thinking...') {
+            return (
+              <Text key={index} variant="muted">
+                {message.content}
+              </Text>
+            );
+          }
+
+          return null;
+        })}
+        <div ref={bottomRef}>
+          <Placeholder height="1.5rem" />
+        </div>
+      </Flex>
+    </ArtifactDetails>
+  );
+}
