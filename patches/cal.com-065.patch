+        nextCursor: undefined,
+        hasMore: false,
+      });
+
+      const result = await service.getHostsForAvailability({
+        eventTypeId: 100,
+        limit: 20,
+      });
+
+      expect(hostRepo.findHostsPaginatedIncludeUser).toHaveBeenCalledWith({
+        eventTypeId: 100,
+        cursor: undefined,
+        limit: 20,
+        search: undefined,
+      });
