+            public CredentialOfferUriResponse send() {
+                CredentialOfferUriResponse response = super.send();
+                ctx.putAttachment(CREDENTIAL_OFFER_URI_ATTACHMENT_KEY, response.getCredentialOfferURI());
+                return response;
+            }
+        };
+        return request;
+    }
