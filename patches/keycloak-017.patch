+            assertThat(response.getStatus(), is(Status.CREATED.getStatusCode()));
+        }
+
+        List<GroupRepresentation> subGroups = orgResource.groups().group(parentId).getSubGroups(null, null, null, null);
+        assertThat(subGroups, hasSize(1));
