diff --git a/frontend/asset-processor/federated-modules-helper.js b/frontend/asset-processor/federated-modules-helper.js
new file mode 100644
index 0000000000000..9b0c5e67024ed
--- /dev/null
+++ b/frontend/asset-processor/federated-modules-helper.js
@@ -0,0 +1,8 @@
+export function federatedExportNameFor(moduleName, exportedName) {
+  if (exportedName === "*") {
+    exportedName = "__module";
+  }
+  return (
+    moduleName.replaceAll("/", "$").replaceAll("-", "__") + "$$" + exportedName
+  );
+}
