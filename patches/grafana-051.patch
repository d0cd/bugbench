+    expect(container).toBeEmptyDOMElement();
+  });
+
+  it('should render nothing when items contains no valid enrichment objects', () => {
+    const { container } = render(<AlertEnrichments enrichments={{ items: ['invalid', 42, null] }} />);
+    expect(container).toBeEmptyDOMElement();
