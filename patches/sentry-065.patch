+          </Container>
+        </Fragment>
+      );
+  }
+
+  return (
+    <Stack
+      flexShrink={0}
+      justify="center"
+      align="center"
+      width="18px"
+      height="18px"
+      data-project-icon
+    >
+      {icons}
+    </Stack>
+  );
+}
+
+interface CollapsibleProps {
+  children: React.ReactNode;
+  collapsed: boolean;
+  disabled?: boolean;
+}
