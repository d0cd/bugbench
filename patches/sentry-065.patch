+        <IconAllProjects size="md" />
+      ) : (
+        <IconMyProjects size="md" />
+      );
+      break;
+    case 1:
+      icons = <PlatformIcon platform={props.projectPlatforms[0]!} size={16} />;
+      break;
+    default:
