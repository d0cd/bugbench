+
+  it('filters overlapping number secondary aliases when boolean version exists', async () => {
+    const organization = OrganizationFixture({
+      features: ['search-query-builder-explicit-boolean-filters'],
+    });
+
+    addAttributeMock('number', [
+      {
+        key: 'custom_metric',
