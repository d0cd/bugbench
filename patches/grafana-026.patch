+	t.Run("chunking issues one Exec per chunk", func(t *testing.T) {
+		t.Parallel()
+
+		sut := testutils.Setup(t)
+		ctx := t.Context()
+		ns := xkube.Namespace("chunk-ns")
+
+		// Create 5 rows in the real DB
+		var created []*contracts.EncryptedValue
+		for i := 1; i <= 5; i++ {
