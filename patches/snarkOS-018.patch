-    /// Mines a new block using the latest state of the given ledger.
-    pub fn mine_next_block<R: Rng + CryptoRng>(
-        &self,
-        recipient: Address<N>,
-        transactions: &[Transaction<N>],
-        terminator: &AtomicBool,
-        rng: &mut R,
