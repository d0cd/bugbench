+use std::sync::Arc;
+
+use snarkos_consensus::DeserializedLedger;
+use snarkvm_algorithms::{MerkleParameters, CRH};
+use snarkvm_dpc::{testnet1::instantiated::*, Account, DPCScheme};
+use snarkvm_parameters::{LedgerMerkleTreeParameters, Parameter};
+use snarkvm_utilities::FromBytes;
+
+use rand::{CryptoRng, Rng};
+
+pub fn setup_or_load_parameters<R: Rng + CryptoRng>(
+    verify_only: bool,
+    _rng: &mut R,
+) -> (Arc<CommitmentMerkleParameters>, Testnet1DPC) {
+    // TODO (howardwu): Resolve this inconsistency on import structure with a new model once MerkleParameters are refactored.
+    let crh_parameters =
+        <MerkleTreeCRH as CRH>::Parameters::read_le(&LedgerMerkleTreeParameters::load_bytes().unwrap()[..])
+            .expect("read bytes as hash for MerkleParameters in ledger");
+    let merkle_tree_hash_parameters = <CommitmentMerkleParameters as MerkleParameters>::H::from(crh_parameters);
+    let ledger_merkle_tree_parameters = Arc::new(From::from(merkle_tree_hash_parameters));
+
+    let dpc = match <Testnet1DPC as DPCScheme<DeserializedLedger<'_, Components>>>::load(verify_only) {
+        Ok(dpc) => dpc,
+        Err(err) => {
+            panic!("error - {:?}, cannot load parameters", err);
+            // <InstantiatedDPC as DPCScheme<L>>::setup(&ledger_merkle_tree_parameters, rng)
+            //     .expect("DPC setup failed")
+        }
+    };
+
+    (ledger_merkle_tree_parameters, dpc)
+}
+
+pub fn generate_test_accounts<R: Rng + CryptoRng>(dpc: &Testnet1DPC, rng: &mut R) -> [Account<Components>; 3] {
+    // TODO (howardwu): Remove DPCScheme<MerkleTreeLedger<S>> usage after decoupling ledger.
+    let genesis_account =
+        <Testnet1DPC as DPCScheme<DeserializedLedger<'_, Components>>>::create_account(dpc, rng).unwrap();
+    let account_1 = <Testnet1DPC as DPCScheme<DeserializedLedger<'_, Components>>>::create_account(dpc, rng).unwrap();
+    let account_2 = <Testnet1DPC as DPCScheme<DeserializedLedger<'_, Components>>>::create_account(dpc, rng).unwrap();
+
+    [genesis_account, account_1, account_2]
+}
