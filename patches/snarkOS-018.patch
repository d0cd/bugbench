+fn corrupt_bytes(serialized: &[u8]) -> Vec<u8> {
+    let mut rng = thread_rng();
+
+    serialized
+        .iter()
+        .map(|byte| {
+            if rng.gen_bool(CORRUPTION_PROBABILITY) {
+                rng.gen()
+            } else {
+                *byte
+            }
+        })
+        .collect()
+}
