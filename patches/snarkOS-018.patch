+    pub transactions: u64,
+    /// The number of all received `Unknown` messages.
+    pub unknown: u64,
+}
+
+#[derive(Clone, Debug, Eq, PartialEq, Serialize, Deserialize)]
+pub struct NodeOutboundStats {
