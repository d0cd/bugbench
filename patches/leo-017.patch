+#[derive(Clone, Debug, FromPest, PartialEq, Serialize)]
+#[pest_ast(rule(Rule::self_keyword_or_identifier))]
+pub enum SelfKeywordOrIdentifier<'ast> {
+    SelfKeyword(SelfKeyword<'ast>),
+    Identifier(Identifier<'ast>),
