+        } catch (ScimClientException sce) {
+            assertNotNull(sce.getError());
+            assertEquals(Status.BAD_REQUEST.getStatusCode(), sce.getError().getStatusInt());
+            assertEquals("Invalid email address.", sce.getError().getDetail());
+        }
