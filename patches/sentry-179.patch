+def catch_provider_exception(fn):
+    @functools.wraps(fn)
+    def wrapper(*args, **kwargs):
+        try:
+            return fn(*args, **kwargs)
+        except ApiError as e:
+            raise SCMProviderException(str(e)) from e
+
+    return wrapper
