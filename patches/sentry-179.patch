+function StarredDashboardItems({
+  dashboards,
+  projects,
+  organizationSlug,
+  organizationId,
+  userId,
+}: {
+  dashboards: DashboardListItem[];
+  organizationId: string;
+  organizationSlug: string;
+  projects: Project[];
+  userId: string;
