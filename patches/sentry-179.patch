+def test_exec_listener():
+    """
+    Test successful execution of a listener.
+    """
+    count = 0
+
+    def record_count(a, b, c):
+        nonlocal count
+        count += 1
+
+    exec_listener("name", {"name": lambda a: None}, 1, record_count)
+    assert count == 0, "Listener could not be executed or failed"
