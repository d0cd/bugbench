+def test_exec_provider_fn():
+    metrics = []
+
+    def record_count(k, a, t):
+        metrics.append((k, a, t))
+
+    provider = BaseTestProvider()
+    result = exec_provider_fn(
+        provider,
+        referrer="emerge",
+        provider_fn=lambda: 42,
