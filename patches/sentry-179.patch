+
+            step.poll()
+            # Give flusher threads time to process after drift change
+            for _ in range(20):
+                step.poll()
+                real_sleep(0.1)
+        finally:
+            fac._flusher.terminate()
+            fac._flusher.join()
+
+    assert len(messages) == 0
