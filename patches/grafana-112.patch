+
+function toHealthCheckResult(v: DatasourcesV0HealthCheckResult): HealthCheckResult {
+  const status: HealthStatus =
+    v.status === HealthStatus.OK || v.status === HealthStatus.Error || v.status === HealthStatus.Unknown
