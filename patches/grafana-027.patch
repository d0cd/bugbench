-// Helper function to count files in a directory recursively
-func countFilesInDir(rootPath string) (int, error) {
-	count := 0
-	err := filepath.WalkDir(rootPath, func(path string, d fs.DirEntry, err error) error {
-		if err != nil {
-			return err
-		}
-		if !d.IsDir() {
-			count++
-		}
-		return nil
-	})
-	return count, err
-}
