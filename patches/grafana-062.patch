+// toMetricsSet converts a slice of metric names to a set for O(1) lookup.
+func toMetricsSet(metrics []string) map[string]bool {
+	set := make(map[string]bool, len(metrics))
+	for _, m := range metrics {
+		set[m] = true
+	}
+	return set
