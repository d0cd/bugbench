+
+func TestMetricsCache_GetMetricsSet_AfterGetMetrics_UsesCachedSet(t *testing.T) {
+	mockProv := &mockProvider{
+		metrics: []string{"metric_a", "metric_b"},
+		ttl:     5 * time.Minute,
+	}
