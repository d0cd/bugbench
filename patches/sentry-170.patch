+    def test_no_dev_dependencies(self) -> None:
+        content = "name: my_app\ndependencies:\n  http: ^0.13.5\n"
+        result = _parse_pubspec_yaml(content)
+        assert result["dependencies"] == {"http"}
+        assert result["dev_dependencies"] == set()
