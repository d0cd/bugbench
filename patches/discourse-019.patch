+      assert.false(VALID_BLOCK_NAME_PATTERN.test(""));
+      assert.false(VALID_BLOCK_NAME_PATTERN.test("123-block"));
+      assert.false(VALID_BLOCK_NAME_PATTERN.test("-block"));
+      assert.false(VALID_BLOCK_NAME_PATTERN.test("Block"));
