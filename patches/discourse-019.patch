+      await validateLayout(
+        entry.children,
+        outletName,
+        blocksService,
+        `${currentPath}.children`,
+        callSiteError,
+        effectiveRootLayout,
+        childArgsSchema,
+        blockName,
+        depth + 1,
+        context
+      );
+    }
+  });
