+          callCount++;
+          throw new Error("Factory failed!");
+        });
+      };
+
+      // Helper to safely resolve (catches the thrown BlockError in DEBUG mode)
+      const safeResolve = async (name) => {
+        try {
+          return await resolveBlock(name);
