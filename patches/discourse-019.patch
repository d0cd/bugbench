+  // If resolution returned null (error was raised), exit early
+  if (resolvedBlock === null) {
+    return null;
+  }
+
+  // Optional block not registered - skip validation entirely
+  if (resolvedBlock?.[OPTIONAL_MISSING]) {
+    return null;
+  }
