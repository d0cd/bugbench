+          },
+        };
+
+        assert.strictEqual(getPageContext("TOP_MENU", services), null);
+      });
+    });
+
+    module("TOPIC_PAGES", function () {
+      test("returns context on topic page", function (assert) {
+        const services = {
+          router: {
