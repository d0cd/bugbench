+const CODE_CHANGES_KEY = Symbol('codeChanges');
+
+type ArtifactKey = string | typeof CODE_CHANGES_KEY;
+type ArtifactOrExplorerFilePatches = Artifact | ExplorerFilePatch[] | RepoPRState[];
