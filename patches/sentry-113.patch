-      {
-        query: {
-          dataset: DiscoverDatasets.ERRORS,
-          query: `issue.id:[${groupIds.join(',')}]`,
-          statsPeriod: '30d',
-          per_page: 50,
-          ...(currentProjects.length ? {project: currentProjects} : {}),
