-    // HH = H^2
-    // I = 4*HH
-    blst_fp i;
-    memcpy(i, h, sizeof(blst_fp));
-    blst_fp_add(i, i, i);
-    blst_fp_sqr(i, i);
-
-    // J = H*I
-    blst_fp j;
-    blst_fp_mul(j, h, i);
-
-    // r = 2*(Y2-Y1)
