-    blst_fp_mul(x_diff_inv3, x_diff_inv2, x_diff_inv);
-
-    blst_fp j;
-    blst_fp_mul(j, y_diff3, x_diff_inv3);
-    blst_fp_sub(out->Y, out->Y, j);
-
-    blst_fp_sub(out->Y, out->Y, p1->Y);
-}
