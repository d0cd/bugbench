-/**
- * Set refresh token function for automatic token refresh
- */
-function setRefreshTokenFunction(
-  refreshFn: (refreshToken: string) => Promise<{ accessToken: string; refreshToken?: string }>
-): void {
-  refreshTokenFunction = refreshFn;
-}
