+
+import type { OnboardingState } from "../../store/onboarding-store";
+import { useSubmitOnboarding } from "../useSubmitOnboarding";
+
+vi.mock("react", async () => {
+  const actual = await vi.importActual<typeof React>("react");
+  return {
+    ...actual,
+    useState: vi.fn((initial: any) => [initial, vi.fn()]),
+  };
+});
+
