+    expect(screen.getByRole('row', {name: 'Northern Europe'})).toBeInTheDocument();
+    expect(screen.queryByRole('row', {name: '21'})).not.toBeInTheDocument();
+    expect(screen.queryByRole('row', {name: '154'})).not.toBeInTheDocument();
+  });
