+        @MockSetup
+        @Override
+        void setup() {
+        }
+    }
+
+    static class GrandParent {
+        @MockSetup
+        void grandParentSetup() {
+        }
+    }
+
+    static class Parent extends GrandParent {
+        @MockSetup
+        void parentSetup() {
+        }
+    }
+
+    static class Child extends Parent {
+        @MockSetup
+        void childSetup() {
+        }
+    }
+
