+
+public class ReflectionUtilsTest {
+
+    @Retention(RetentionPolicy.RUNTIME)
+    @Target(ElementType.METHOD)
+    @interface MockSetup {
+    }
+
+    static class SuperClass {
+        @MockSetup
+        void superSetup() {
+        }
+    }
+
+    static class SubClass extends SuperClass {
+        @MockSetup
+        void subSetup() {
+        }
+    }
+
+    static class BaseWithSetup {
+        @MockSetup
