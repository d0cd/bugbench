+			Push:   &provisioning.ExportJobOptions{},
+		}
+
+		err := c.authorizeResourceJob(ctx, mockRepo, cfg, spec)
+		require.Error(t, err)
+		assert.True(t, apierrors.IsBadRequest(err))
+	})
