+		clientsMock := resources.NewMockClientFactory(t)
+
+		c := &jobsConnector{access: accessMock, clients: clientsMock}
+		err := c.authorizeDeleteJob(ctx, mockReader, cfg, &provisioning.DeleteJobOptions{})
+		require.NoError(t, err)
