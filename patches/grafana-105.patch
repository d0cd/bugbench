+		mockReader := repository.NewMockReader(t)
+
+		c := &jobsConnector{access: accessMock, folderMetadataEnabled: false}
+		spec := provisioning.JobSpec{
+			Action: provisioning.JobActionPush,
+			Push:   &provisioning.ExportJobOptions{},
+		}
