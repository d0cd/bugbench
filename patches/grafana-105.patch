+func newTestReconciler(pages [][]*openfgav1.Tuple) *Reconciler {
+	return &Reconciler{
+		server: &mockServerInternal{fga: &mockOpenFGAServer{pages: pages}},
+		tracer: tracing.NewNoopTracerService(),
+	}
+}
