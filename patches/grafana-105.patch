+const baseCondition: ClassicCondition = {
+  type: 'query',
+  evaluator: { params: [0], type: EvalFunction.IsAbove },
+  query: { params: ['A'] },
+  reducer: { params: [], type: 'avg' },
+};
+
+const defaultProps = {
+  onChange: jest.fn(),
+  onRemoveCondition: jest.fn(),
+  index: 0,
+  refIds: [{ value: 'A', label: 'A' }],
