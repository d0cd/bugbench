+            ratifications,
+            transactions,
+            aborted_transaction_ids,
+            ratified_finalize_operations,
+            rng,
+        )
+        .unwrap();
+        vm.add_next_block(&block).unwrap();
+    }
+
     (vm, records)
 }
 
