index 000000000..c036b7d70
--- /dev/null
+++ b/synthesizer/process/src/stack/helpers/check_upgrade.rs
@@ -0,0 +1,129 @@
+// Copyright (c) 2019-2025 Provable Inc.
+// This file is part of the snarkVM library.
