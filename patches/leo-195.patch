+
+#[test]
+fn test_circuit_explicit_define() {
+    let program_string = r#"
+    circuit One {
+        x: u8,
+    }
+    function main () {
+        let x: One = One {x: 5};
+    }
+    "#;
+    load_asg(program_string).unwrap();
+}
