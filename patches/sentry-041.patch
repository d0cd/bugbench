+            </field.Layout.Stack>
+          )}
+        </form.AppField>
+        <form.AppField name="field4">
+          {field => (
+            <field.Layout.Stack
+              label="Compact Variant"
+              hintText="This hint text appears in a tooltip when hovering the label"
+              variant="compact"
+            >
+              <field.Input value={field.state.value} onChange={field.handleChange} />
+            </field.Layout.Stack>
+          )}
+        </form.AppField>
+      </FieldGroup>
+    </form.AppForm>
