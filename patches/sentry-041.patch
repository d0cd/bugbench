+                }
+                value={source}
+                error={errors?.source}
+                onBlur={(value, _event) => {
+                  this.handleValidateAttributeField(value);
+                  onValidate('source')();
+                }}
+                projectId={projectId}
+              />
+            </Fragment>
+          )}
+        </SourceGroup>
+      </Fragment>
+    );
+  }
+
+  render() {
+    const {
