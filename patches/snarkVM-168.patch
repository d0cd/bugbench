+
+impl<N: Network> FromStr for Authorization<N> {
+    type Err = Error;
+
+    /// Initializes the authorization from a JSON-string.
+    fn from_str(authorization: &str) -> Result<Self, Self::Err> {
+        Ok(serde_json::from_str(authorization)?)
+    }
