+
+            # ...but the in-memory value is set anyway
+            assert p4.env("P4TRUST") == expected
+        finally:
+            if old_enviro is not None:
+                os.environ["P4ENVIRO"] = old_enviro
+            else:
+                os.environ.pop("P4ENVIRO", None)
