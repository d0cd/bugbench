+      await applyScopes(page);
+
+      // Should now redirect from cuj-dashboard-3 to cuj-dashboard-2
+      await expect(page).toHaveURL(/\/d\/cuj-dashboard-2/);
+      await expect(page).toHaveURL(/scopes=scope-sn-redirect-fallback/);
+    });
+  });
 });
