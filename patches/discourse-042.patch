diff --git a/lib/onebox/helpers.rb b/lib/onebox/helpers.rb
index 7c57c0411e8c3..034d7fc9cbcb2 100644
--- a/lib/onebox/helpers.rb
+++ b/lib/onebox/helpers.rb
@@ -286,5 +286,20 @@ def self.map_placeholder_html
     def self.generic_placeholder_html
       "<div class='onebox-placeholder-container'><span class='placeholder-icon generic'></span></div>"
     end
+
+    def self.normalize_dropbox_url(url)
+      return url unless url.start_with?("https://www.dropbox.com/")
+
+      uri = URI.parse(url)
+      uri.host = "dl.dropboxusercontent.com"
+
+      if url.include?("/scl/")
+        params = URI.decode_www_form(uri.query.to_s).to_h
+        params["raw"] = "1"
+        uri.query = URI.encode_www_form(params)
+      end
+
+      uri.to_s
+    end
   end
 end
