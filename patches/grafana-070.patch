new file mode 100644
index 0000000000000..59d442108b55f
--- /dev/null
+++ b/.github/actions/report-go-cache-sizes/action.yml
@@ -0,0 +1,7 @@
+name: Report Go Cache Sizes
+description: Logs GOMODCACHE and GOCACHE sizes. Runs at setup time and again as a post step at the end of the job.
+
+runs:
+  using: node20
+  main: index.js
+  post: index.js
diff --git a/.github/actions/report-go-cache-sizes/index.js b/.github/actions/report-go-cache-sizes/index.js
new file mode 100644
index 0000000000000..646636ff9e1ac
--- /dev/null
+++ b/.github/actions/report-go-cache-sizes/index.js
@@ -0,0 +1,18 @@
+const { execSync } = require("child_process");
+
+function size(dir) {
+  try {
+    return execSync(`du -sh "${dir}" 2>/dev/null`).toString().trim().split("\t")[0];
+  } catch {
+    return "N/A";
+  }
+}
+
+try {
+  const gomodcache = execSync("go env GOMODCACHE").toString().trim();
+  const gocache = execSync("go env GOCACHE").toString().trim();
+  console.log(`GOMODCACHE: ${size(gomodcache)} (${gomodcache})`);
+  console.log(`GOCACHE:    ${size(gocache)} (${gocache})`);
+} catch (e) {
+  console.log("Could not determine Go cache sizes:", e.message);
+}
diff --git a/.github/actions/setup-go/action.yml b/.github/actions/setup-go/action.yml
index ecf16e0f44731..c8665cd4cbccf 100644
--- a/.github/actions/setup-go/action.yml
+++ b/.github/actions/setup-go/action.yml
@@ -10,12 +10,36 @@ inputs:
     description: Whether to cache Go modules and build cache.
     required: false
     default: 'true'
+  cache-build:
+    description: >-
+      Whether to also cache the Go build cache (GOCACHE).
+      Set to 'false' for jobs that don't compile much (lint, codegen, checks).
+      When 'false', only GOMODCACHE is cached via actions/cache.
+    required: false
+    default: 'true'
 
 runs:
   using: "composite"
   steps:
+    # When cache-build is enabled, use the built-in setup-go caching
+    # which stores both GOMODCACHE and GOCACHE together.
     - uses: actions/setup-go@v6.0.0
       with:
         go-version-file: ${{ inputs.go-version-file }}
-        cache: ${{ inputs.cache == 'true' }}
-        cache-dependency-path: ${{ inputs.cache == 'true' && '**/*.mod' || '' }}
+        cache: ${{ inputs.cache == 'true' && inputs.cache-build == 'true' }}
+        cache-dependency-path: ${{ inputs.cache == 'true' && inputs.cache-build == 'true' && '**/*.mod' || '' }}
+
+    # When cache-build is disabled, cache only GOMODCACHE via actions/cache.
+    # This avoids restoring/saving the large GOCACHE (~5 GB) for jobs that
+    # do little or no compilation (lint, codegen, workspace checks).
+    - name: Cache Go modules only
+      if: inputs.cache == 'true' && inputs.cache-build != 'true'
+      uses: actions/cache@v4
+      with:
+        path: ~/go/pkg/mod
+        key: gomod-${{ runner.os }}-${{ runner.arch }}-${{ hashFiles('**/*.mod') }}
+        restore-keys: gomod-${{ runner.os }}-${{ runner.arch }}-
+
+    - name: Report Go cache sizes
+      if: inputs.cache == 'true'
+      uses: ./.github/actions/report-go-cache-sizes
