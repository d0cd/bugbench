diff --git a/tests/compiler/statements/typecheck_statements_fail.leo b/tests/compiler/statements/typecheck_statements_fail.leo
new file mode 100644
index 0000000000..512eb7d88f
--- /dev/null
+++ b/tests/compiler/statements/typecheck_statements_fail.leo
@@ -0,0 +1,14 @@
+/*
+namespace: Compile
+expectation: Fail
+*/
+
+@program
+function main() -> bool {
+    let c1 : u32 = 123i16 * 123i32;
+    let c2 : u32 = "123i32" * 123i16 * "sss";
+    let c3 : u32 = "123i32" * "sss";
+    let c4 : u32 = 1i8 * 2i16 * 3i32 * 4i64 * 5u8 * 6u16 * 7u32 * 9u64;
+    let c16: bool = ("123i32" & 123i16) == ("sss" / 1i8 - 1i8 + 22u32);
+    return false;
+}
