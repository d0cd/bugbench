+use super::*;
+
+impl<E: Environment> Div<Self> for Field<E> {
+    type Output = Self;
+
+    fn div(self, other: Self) -> Self::Output {
+        self / &other
+    }
+}
+
+impl<E: Environment> Div<&Self> for Field<E> {
+    type Output = Self;
+
+    fn div(self, other: &Self) -> Self::Output {
+        let mut output = self;
+        output /= other;
+        output
+    }
+}
+
+impl<E: Environment> DivAssign<Self> for Field<E> {
+    fn div_assign(&mut self, other: Self) {
+        *self /= &other;
+    }
+}
+
+impl<E: Environment> DivAssign<&Self> for Field<E> {
+    #[allow(clippy::suspicious_op_assign_impl)]
+    fn div_assign(&mut self, other: &Self) {
+        *self *= other.inv();
+    }
+}
+
