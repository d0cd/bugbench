+                for (expected_bit, candidate_bit) in expected_bits.iter().zip_eq(&candidate_bits_le[0..I::BITS]) {
+                    assert_eq!(expected_bit, candidate_bit);
+                }
+
+                // Ensure all remaining bits are 0.
+                for candidate_bit in &candidate_bits_le[I::BITS..] {
